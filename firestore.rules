rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /students/{studentId} {
      allow read, write: if true;
    }

    match /attendance_logs/{logId} {
      allow read, write: if true;
    }

    match /attendance_keys/{keyId} {
      allow read, write: if true;
    }
  }
}
